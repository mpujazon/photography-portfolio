generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AlbumLayoutType {
  GRID
  MASONRY
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Album {
  id           String          @id @default(uuid()) @db.Uuid
  title        String
  slug         String          @unique
  description  String?
  layoutType   AlbumLayoutType @default(GRID)
  orderIndex   Int             @default(0)
  coverPhotoId String?         @db.Uuid
  coverPhoto   Photo?          @relation("AlbumCover", fields: [coverPhotoId], references: [id])
  photos       Photo[]         @relation("AlbumPhotos")
  isPublished  Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Photo {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  imageUrl     String
  cloudinaryId String?
  category     String?
  description  String?
  albumId      String?  @db.Uuid
  album        Album?   @relation("AlbumPhotos", fields: [albumId], references: [id])
  coverOfAlbum Album[]  @relation("AlbumCover")
  orderIndex   Int      @default(0)
  isFeatured   Boolean  @default(false)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
